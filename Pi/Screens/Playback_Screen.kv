#:import Factory kivy.factory.Factory
<DescriptionPopup@Popup>:
    title: 'Recorded ISS Data Descriptions'
    size_hint: 0.6, 0.4
    auto_dismiss: True

    BoxLayout:
        orientation: 'vertical'
        ScrollView:
            do_scroll_x: False  # Disabling horizontal scrolling
            do_scroll_y: True   # Enabling vertical scrolling

            # You can add your content inside this GridLayout
            GridLayout:
                cols: 1
                size_hint_y: None
                height: self.minimum_height  # Important for scrolling
                # Add your widgets here

                #Label:
                #    text: 'This will playback recorded data from when the Japanese HTV spacecraft berthed to the ISS. During berthing, the SARJs and nadir BGAs lock but the zenith BGAs autotrack'
                #    padding: 10, 10
                #    halign: 'center'
                #    text_size: self.width - 20, None

                # Example of a text box with ISS information
                Label:
                    text: 'This will playback recorded data from when the Japanese HTV spacecraft berthed to the ISS. During berthing, the SARJs and nadir BGAs lock but the zenith BGAs autotrack'
                    size_hint_y: None
                    height: self.texture_size[1] + 20  
                    text_size: self.width, None  
                    halign: 'left'
                    valign: 'middle'

                Label:
                    text: 'ISS Info 2: [More ISS info here]'
                    size_hint_y: None
                    height: self.texture_size[1] + 20
                    text_size: self.width, None
                    halign: 'left'
                    valign: 'middle'

                Label:
                    text: 'ISS Info 2: [More ISS info here]'
                    size_hint_y: None
                    height: self.texture_size[1] + 20
                    text_size: self.width, None
                    halign: 'left'
                    valign: 'middle'

                Label:
                    text: 'ISS Info 2: [More ISS info here]'
                    size_hint_y: None
                    height: self.texture_size[1] + 20
                    text_size: self.width, None
                    halign: 'left'
                    valign: 'middle'

                Label:
                    text: 'ISS Info 2: [More ISS info here]'
                    size_hint_y: None
                    height: self.texture_size[1] + 20
                    text_size: self.width, None
                    halign: 'left'
                    valign: 'middle'

                Label:
                    text: 'DEmo orbit 2'
                    padding: 10, 10
                    halign: 'center'
                    text_size: self.width - 20, None

<ImageButton>:
    background_normal: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/InfoIcon.png'
    fit_mode: "scale-down"

<Playback_Screen>:
    name: 'playback'
    FloatLayout:
        orientation: 'vertical'
        Image:
            source: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/SimulatedOrbitBackground.png'
            fit_mode: "fill"
        Spinner:
            id: playback_dropdown
            size_hint: 0.175, 0.1
            pos_hint: {"center_x": 0.155, "center_y": 0.55}
            text: 'Select Data'
            values: ['HTV','OFT-2']
            on_text: root.on_dropdown_select(self.text)
            on_release: start.background_color = 0,1,0,1
        Label:
            id: playbackstatus
            text: ''
            size_hint_y: 0.4
            font_size: self.height * 0.2
            pos_hint: {"center_x": 0.5, "center_y": 0.08}
            markup: True
            color: 1,1,1
        Button:
            id: popup
            text: ''
            size_hint: 0.1,0.1
            pos_hint: {"center_x": 0.25, "center_y": 0.8}
            background_color: 0,0,0,0
            on_release: Factory.DescriptionPopup().open()
            Image:
                source: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/InfoIcon.png'
                center_x: self.parent.center_x
                center_y: self.parent.center_y
        Button:
            id: Disco
            size_hint: 0.14,0.115
            text: "Disco!"
            font_size: dp(30)
            pos_hint: {"center_x": 0.8, "center_y": 0.55}
            on_release: playbackstatus.text = 'Ready to Disco'
            on_release: root.on_disco_select("Disco")
            on_release: start.background_color = 0,1,0,1
        Button:
            id: start
            size_hint: 0.1,0.115
            pos_hint: {"center_x": 0.2, "center_y": 0.25}
            background_color: 1,0.3,0.4,0.85
            background_normal: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/StartUnlit.png'
            background_down: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/StartDown.png'
            on_release: stop.background_color = 1,0,0,1
            on_release: playback_dropdown.disabled = True
            on_release: stop.disabled = False
            on_release: playbackstatus.text = 'Beginning Playback'
            on_release: root.changeDemoBoolean(True)
            on_release: self.disabled = True
            on_release: root.start_press()
        Button:
            id: stop
            size_hint: 0.1,0.115
            pos_hint: {"center_x": 0.8, "center_y": 0.25}
            background_normal: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/StopUnlit.png'
            background_down: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/StopDown.png'
            disabled: True
            on_release: start.background_color = 0,0,0,0
            on_release: self.background_color = 0,0,0,0
            on_release: playback_dropdown.disabled = False
            on_release: start.disabled = False
            on_release: playbackstatus.text = 'Stopped'
            on_release: root.changeDemoBoolean(False)
            on_release: self.disabled = True
            on_release: root.stop_press()
        Label:
            id: time_factor_label
            text: str(root.time_factor) + "x"
            size_hint_y: 0.3
            font_size: self.height * 0.2
            pos_hint: {"center_x": 0.48, "center_y": 0.55}
            markup: True
            color: 1,1,1
            
        Button:
            id: time_plus
            size_hint: 0.08,0.12
            pos_hint: {"center_x": 0.54, "center_y": 0.45}
            background_normal: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/PBplusUnlit.png'
            background_down: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/PBplusDown.png'
            on_release: root.increment_time()
        Button:
            id: time_minus
            size_hint: 0.09,0.07
            pos_hint: {"center_x": 0.44, "center_y": 0.45}
            background_normal: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/PBminusUnlit.png'
            background_down: f'{root.mimic_directory}/Mimic/Pi/imgs/playback/PBminusDown.png'
            on_release: root.decrement_time()
        Button:
            size_hint: 0.1,0.11
            pos_hint: {"center_x": 0.9375, "center_y": 0.082}
            background_normal: f'{root.mimic_directory}/Mimic/Pi/imgs/eva/BackButton.png'
            on_release: start.background_color = 0,0,0,0
            on_release: start.disabled = False
            on_release: stop.disabled = True
            on_release: root.changeDemoBoolean(False)
            on_release: root.stop_press()
            on_release: root.manager.current = 'main'
        Image:
            id: signal
            source: f"{root.mimic_directory}/Mimic/Pi/imgs/signal/pulse-transparent.zip"
            size_hint_y: 0.15
            anim_delay: 0.12
            anim_loop: 0
            pos_hint: {"center_x": 0.05, "center_y": 0.07}
            fit_mode: "scale-down"
        Image:
            id: arduino
            source: f"{root.mimic_directory}/Mimic/Pi/imgs/signal/arduino_offline.png"
            size_hint_y: 0.15
            anim_delay: 0.2
            anim_loop: 0
            pos_hint: {"center_x": 0.14, "center_y": 0.08}
            fit_mode: "scale-down"
        Label:
            id: arduino_count
            pos_hint: {"center_x": 0.14, "center_y": 0.08}
            text: ''
            markup: True
            color: 1,1,1
            font_size: self.height * 0.3
            size_hint_y: 0.5
